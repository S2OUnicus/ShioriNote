        echo "<div class=\"uk-alert-$type\" uk-alert><a class=\"uk-alert-close\" uk-close></a><p>$msg</p></div>";
    }
}

function minify_html_output(string $html): string
{
    $keep = [];
    $html = preg_replace_callback('/<(pre|textarea)\b[^>]*>.*?<\/\1>/is', function (array $m) use (&$keep): string {
        $key = '%%RPM_KEEP_' . count($keep) . '%%';
        $keep[$key] = $m[0];
        return $key;
    }, $html) ?? $html;
    $html = preg_replace('/<!--(?!\[if).*?-->/s', '', $html) ?? $html;
    $html = preg_replace('/>\s+</', '><', $html) ?? $html;
    $html = preg_replace('/\s{2,}/', ' ', $html) ?? $html;
    $html = trim($html);
    return strtr($html, $keep);
}

function start_minify(): void
{
    ob_start('minify_html_output');
}
