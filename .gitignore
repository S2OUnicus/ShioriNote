# Local/editor files
/.idea/
/.vscode/
.DS_Store
Thumbs.db
*.log
*.tmp
*.bak

# Dependency and environment files
/vendor/
.env

# Private runtime configuration
/config/base.inc.phtml
/config/base.inc.phtml-*.bak
/public/.user.ini
/install.lock

# Local database files and private SQL dumps
/database/
*.sql.gz
*.dump
*.backup

# Runtime uploads
/public/upload/avatar/*
!/public/upload/avatar/.gitkeep
!/public/upload/avatar/default-avatar.svg
/public/upload/book/*
!/public/upload/book/.gitkeep
!/public/upload/book/default-cover.svg
logs/*.log
logs/*.txt
/update.lock
/backup/database/*.sql
/backup/database/*.sql.gz
!/backup/database/.gitkeep
