<?php
$user = require_login();
$pageDescription = 'ユーザー情報、パスワード、タイムゾーン、IDを修正できます。';
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    verify_csrf();
    $action = (string)($_POST['action'] ?? '');
    if ($action === 'profile') {
        try {
            $loginId = validate_login_id((string)($_POST['login_id'] ?? $user['login_id']));
        } catch (Throwable $e) {
            app_flash('danger', $e->getMessage());
            $loginId = (string)$user['login_id'];
        }
        $email = trim((string)($_POST['email'] ?? ''));
        $nickname = clean_text((string)($_POST['nickname'] ?? ''), 80);
        $bio = clean_text((string)($_POST['bio'] ?? ''), 2000);
        $link = clean_url((string)($_POST['link_url'] ?? ''));
        $timezone = in_array((string)($_POST['timezone'] ?? ''), timezone_identifiers_list(), true) ? (string)$_POST['timezone'] : $user['timezone'];
        if (!filter_var($email, FILTER_VALIDATE_EMAIL)) {
            app_flash('danger', 'メール形式が正しくありません。');
        } elseif (login_id_exists($loginId, (int)$user['uid'])) {
            app_flash('danger', 'このIDは既に使われています。大文字と小文字だけが違うIDも同じIDとして扱います。');
        } elseif (email_exists($email, (int)$user['uid'])) {
            app_flash('danger', 'このメールは既に使われています。');
        } else {
            $avatarPath = safe_image_upload($_FILES['avatar'] ?? [], app_config('uploads')['avatar_dir'], 'avatar') ?? $user['avatar_path'];
            $stmt = db()->prepare('UPDATE users SET login_id=?, email=?, nickname=?, avatar_path=?, bio=?, link_url=?, timezone=?, updated_at_utc=UTC_TIMESTAMP(6) WHERE uid=?');
            $stmt->execute([$loginId, $email, $nickname, $avatarPath, $bio, $link, $timezone, (int)$user['uid']]);
            app_flash('success', '個人情報を更新しました。');
            redirect_to('user');
        }
    }
    if ($action === 'password') {
        $current = (string)($_POST['current_password'] ?? '');
        $new = (string)($_POST['new_password'] ?? '');
        if (!verify_password_bundle($current, $user['password_salt'], $user['password_hash'])) {
            app_flash('danger', '現在のパスワードが正しくありません。');
        } elseif (strlen($new) < 8) {
            app_flash('danger', '新しいパスワードは8文字以上にしてください。');
        } else {
            $bundle = create_password_bundle($new);
            $stmt = db()->prepare('UPDATE users SET password_salt=?, password_hash=?, updated_at_utc=UTC_TIMESTAMP(6) WHERE uid=?');
            $stmt->execute([$bundle['salt'], $bundle['hash'], (int)$user['uid']]);
            app_flash('success', 'パスワードを変更しました。');
            redirect_to('user');
        }
    }
}
$tzs = timezone_identifiers_list();
?><section class="uk-card uk-card-default uk-card-body rpm-card uk-margin"><div class="uk-flex uk-flex-middle uk-flex-wrap" style="gap:18px"><img class="rpm-avatar-lg" src="<?php echo e(asset_url($user['avatar_path'] ?: '/upload/avatar/default-avatar.svg')); ?>" alt="avatar"><div><h1>ユーザーセンター</h1><p class="uk-text-lead"><?php echo e($user['nickname'] ?: $user['login_id']); ?></p><p class="rpm-muted">UID: <?php echo e($user['uid']); ?> / ID: <?php echo e($user['login_id']); ?> / 権限: <?php echo e(role_label_ja((string)$user['role'])); ?></p><?php if (($user['role'] ?? '') === 'banned'): ?><div class="uk-alert-danger" uk-alert>禁止中のため進展管理は利用できません。データは保持されています。</div><?php endif; ?></div></div></section><div class="uk-grid-large uk-child-width-1-2@m" uk-grid><section><div class="uk-card uk-card-default uk-card-body rpm-card"><h2>個人情報修正</h2><form method="post" enctype="multipart/form-data" action="<?php echo e(url_for('user')); ?>"><?php echo csrf_field(); ?><input type="hidden" name="action" value="profile"><div class="uk-margin"><label>UID<input class="uk-input" value="<?php echo e($user['uid']); ?>" disabled></label></div><div class="uk-margin"><label>ID<input class="uk-input" name="login_id" value="<?php echo e($user['login_id']); ?>" required pattern="[A-Za-z0-9]{1,16}" maxlength="16"></label><p class="uk-text-meta">IDは16桁以内の半角英数字です。大文字と小文字だけが違うIDは同じIDとして扱います。</p></div><div class="uk-margin"><label>メール<input class="uk-input" type="email" name="email" value="<?php echo e($user['email']); ?>" required></label></div><div class="uk-margin"><label>あだ名<input class="uk-input" name="nickname" value="<?php echo e($user['nickname']); ?>"></label></div><div class="uk-margin"><label>アバター<input class="uk-input" type="file" name="avatar" accept="image/png,image/jpeg,image/webp"></label></div><div class="uk-margin"><label>個人紹介<textarea class="uk-textarea" name="bio" rows="4" maxlength="2000"><?php echo e($user['bio']); ?></textarea></label></div><div class="uk-margin"><label>リンク<input class="uk-input" type="url" name="link_url" value="<?php echo e($user['link_url']); ?>"></label></div><div class="uk-margin"><label>タイムゾーン<select class="uk-select" name="timezone"><?php foreach ($tzs as $tz): ?><option value="<?php echo e($tz); ?>" <?php echo $tz === $user['timezone'] ? 'selected' : ''; ?>><?php echo e($tz); ?></option><?php endforeach; ?></select></label></div><button class="uk-button uk-button-primary" type="submit">保存</button></form></div></section><section><div class="uk-card uk-card-default uk-card-body rpm-card"><h2>パスワード修正</h2><form method="post" action="<?php echo e(url_for('user')); ?>"><?php echo csrf_field(); ?><input type="hidden" name="action" value="password"><div class="uk-margin"><label>現在のパスワード<input class="uk-input" type="password" name="current_password" autocomplete="current-password" required></label></div><div class="uk-margin"><label>新しいパスワード<input class="uk-input" type="password" name="new_password" minlength="8" autocomplete="new-password" required></label></div><button class="uk-button uk-button-primary" type="submit">変更</button></form></div></section></div>
