<?php
$user = require_not_banned();
$pageDescription = '自分で追加した図書を管理できます。';
function sn_my_books_url(array $params = []): string { return url_for('my-books', $params); }
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    verify_csrf();
    $action = (string)($_POST['action'] ?? '');
    if ($action === 'create_book' || $action === 'update_book') {
        $bookId = (int)($_POST['book_id'] ?? 0);
        $book = $action === 'update_book' ? require_own_book($bookId, $user) : null;
        $title = clean_text((string)($_POST['title'] ?? ''), 255);
        if ($title === '') { app_flash('danger', '図書名は必須です。'); redirect_to('my-books'); }
        $author = clean_text((string)($_POST['author'] ?? ''), 255);
        $publisher = clean_text((string)($_POST['publisher'] ?? ''), 255);
        $memo = clean_text((string)($_POST['memo'] ?? ''), 4000);
        $unit = in_array((string)($_POST['progress_unit'] ?? 'section'), ['chapter','section','subsection'], true) ? (string)$_POST['progress_unit'] : 'section';
        $bucket = (($_POST['progress_time_bucket'] ?? 'daily') === 'hourly') ? 'hourly' : 'daily';
        $mindmapDepth = in_array((string)($_POST['mindmap_depth'] ?? 'section'), ['chapter','section','subsection'], true) ? (string)$_POST['mindmap_depth'] : 'section';
        $mindmapRoot = (($_POST['mindmap_root'] ?? 'chapter') === 'book') ? 'book' : 'chapter';
        $chapterChartStyle = (($_POST['chapter_chart_style'] ?? 'rounded') === 'horizontal') ? 'horizontal' : 'rounded';
        $cover = safe_image_upload($_FILES['cover'] ?? [], app_config('uploads')['book_dir'], 'book') ?? ($book['cover_path'] ?? '');
        if ($action === 'create_book') {
            $stmt = db()->prepare('INSERT INTO books(title,author,publisher,cover_path,memo,progress_unit,progress_time_bucket,mindmap_depth,mindmap_root,chapter_chart_style,created_by,created_at_utc,updated_at_utc) VALUES(?,?,?,?,?,?,?,?,?,?,?,UTC_TIMESTAMP(6),UTC_TIMESTAMP(6))');
            $stmt->execute([$title, $author, $publisher, $cover, $memo, $unit, $bucket, $mindmapDepth, $mindmapRoot, $chapterChartStyle, (int)$user['uid']]);
            app_flash('success', '図書を追加しました。');
        } else {
            $stmt = db()->prepare('UPDATE books SET title=?, author=?, publisher=?, cover_path=?, memo=?, progress_unit=?, progress_time_bucket=?, mindmap_depth=?, mindmap_root=?, chapter_chart_style=?, updated_at_utc=UTC_TIMESTAMP(6) WHERE book_id=? AND created_by=?');
            $stmt->execute([$title, $author, $publisher, $cover, $memo, $unit, $bucket, $mindmapDepth, $mindmapRoot, $chapterChartStyle, $bookId, (int)$user['uid']]);
            app_flash('success', '図書情報を更新しました。');
        }
        redirect_to('my-books');
    }
    if ($action === 'import_toc') {
        $bookId = (int)($_POST['book_id'] ?? 0);
        require_own_book($bookId, $user);
        if (($_FILES['toc_file']['error'] ?? UPLOAD_ERR_NO_FILE) !== UPLOAD_ERR_OK) {
            app_flash('danger', '目次ファイルを選択してください。');
        } elseif (($_FILES['toc_file']['size'] ?? 0) > app_config('uploads')['max_toc_bytes']) {
            app_flash('danger', '目次ファイルは1MB以内にしてください。');
        } else {
            $name = (string)($_FILES['toc_file']['name'] ?? '');
            $ext = strtolower(pathinfo($name, PATHINFO_EXTENSION));
            if (!in_array($ext, ['txt','md'], true)) {
                app_flash('danger', '目次ファイルは .txt または .md のみ利用できます。');
            } else {
                $text = file_get_contents($_FILES['toc_file']['tmp_name']);
                if ($text === false) { throw new RuntimeException('目次ファイルを読み込めません。'); }
                $rows = parse_toc_text($text);
                if (!$rows) { app_flash('danger', '導入できる目次行がありません。'); }
                else {
                    db()->beginTransaction();
                    try {
                        db()->prepare('DELETE FROM book_toc WHERE book_id = ?')->execute([$bookId]);
                        $parents = [0 => null, 1 => null, 2 => null, 3 => null];
                        $sort = 10;
                        foreach ($rows as $row) {
                            $level = (int)$row['level'];
                            $parentId = $level === 1 ? null : ($parents[$level - 1] ?? null);
                            if ($level > 1 && $parentId === null) { $level = 1; }
                            $stmt = db()->prepare('INSERT INTO book_toc(book_id,parent_id,level,sort_order,title,created_at_utc) VALUES(?,?,?,?,?,UTC_TIMESTAMP(6))');
                            $stmt->execute([$bookId, $parentId, $level, $sort, $row['title']]);
                            $parents[$level] = (int)db()->lastInsertId();
                            for ($i = $level + 1; $i <= 3; $i++) { $parents[$i] = null; }
                            $sort += 10;
                        }
                        db()->commit();
                        app_flash('success', '目次を導入しました。');
                    } catch (Throwable $e) { db()->rollBack(); throw $e; }
                }
            }
        }
        redirect_to('my-books');
    }
}
$stmt = db()->prepare('SELECT b.*, COUNT(t.toc_id) AS toc_count FROM books b LEFT JOIN book_toc t ON t.book_id=b.book_id WHERE b.created_by=? GROUP BY b.book_id ORDER BY b.book_id DESC LIMIT 200');
$stmt->execute([(int)$user['uid']]);
$books = $stmt->fetchAll();
?>
