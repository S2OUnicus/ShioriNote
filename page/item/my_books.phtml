r" value="<?php echo e($b['publisher']); ?>"></label><label>写真<input class="uk-input" type="file" name="cover" accept="image/png,image/jpeg,image/webp" data-preview-target="#my-cover-preview-<?php echo e($bid); ?>"></label><label>進展管理単位<select class="uk-select" name="progress_unit"><option value="section" <?php echo $b['progress_unit']==='section'?'selected':''; ?>>節</option><option value="chapter" <?php echo $b['progress_unit']==='chapter'?'selected':''; ?>>章</option><option value="subsection" <?php echo $b['progress_unit']==='subsection'?'selected':''; ?>>小節</option></select></label><label>進展時間粒度<select class="uk-select" name="progress_time_bucket"><option value="daily" <?php echo ($b['progress_time_bucket'] ?? 'daily')==='daily'?'selected':''; ?>>日別</option><option value="hourly" <?php echo ($b['progress_time_bucket'] ?? 'daily')==='hourly'?'selected':''; ?>>時間別</option></select></label><label>マインドマップ詳細度<select class="uk-select" name="mindmap_depth"><option value="chapter" <?php echo ($b['mindmap_depth'] ?? 'section')==='chapter'?'selected':''; ?>>章まで</option><option value="section" <?php echo ($b['mindmap_depth'] ?? 'section')==='section'?'selected':''; ?>>節まで</option><option value="subsection" <?php echo ($b['mindmap_depth'] ?? 'section')==='subsection'?'selected':''; ?>>小節まで</option></select></label><label>マインドマップルート<select class="uk-select" name="mindmap_root"><option value="chapter" <?php echo ($b['mindmap_root'] ?? 'chapter')==='chapter'?'selected':''; ?>>章から表示</option><option value="book" <?php echo ($b['mindmap_root'] ?? 'chapter')==='book'?'selected':''; ?>>図書名から表示</option></select></label><label>章ごと完成度 初期チャート<select class="uk-select" name="chapter_chart_style"><option value="rounded" <?php echo ($b['chapter_chart_style'] ?? 'rounded')==='rounded'?'selected':''; ?>>丸棒</option><option value="horizontal" <?php echo ($b['chapter_chart_style'] ?? 'rounded')==='horizontal'?'selected':''; ?>>横棒</option></select></label></div><div class="uk-margin"><label>メモ<te