<?php
$pageDescription = '登録済み図書をGRIDで表示します。';
$stmt = db()->query('SELECT b.*, COUNT(t.toc_id) AS toc_count FROM books b LEFT JOIN book_toc t ON t.book_id = b.book_id GROUP BY b.book_id ORDER BY b.created_at_utc DESC');
$books = $stmt->fetchAll();
?><section class="uk-margin-bottom"><h1>図書リスト</h1><p class="rpm-muted">図書詳細から、ユーザー別の読書進展管理ページへ進めます。</p></section><?php if (!$books): ?><div class="uk-alert-warning" uk-alert><p>まだ図書が登録されていません。管理システムから追加してください。</p></div><?php else: ?><div class="rpm-grid"><?php foreach ($books as $book): ?><article class="uk-card uk-card-default rpm-card"><div class="uk-card-media-top uk-padding-small"><img class="rpm-book-cover" src="<?php echo e(asset_url($book['cover_path'] ?: '/upload/book/default-cover.svg')); ?>" alt="<?php echo e($book['title']); ?>"></div><div class="uk-card-body"><h3 class="uk-card-title"><?php echo e($book['title']); ?></h3><p class="uk-text-meta"><?php echo e($book['author'] ?: '作者未設定'); ?> / <?php echo e($book['publisher'] ?: '発行機関未設定'); ?></p><p>管理単位：<?php echo e(match($book['progress_unit']) {'chapter'=>'章','subsection'=>'小節',default=>'節'}); ?> / 目次：<?php echo e($book['toc_count']); ?>件</p><a class="uk-button uk-button-primary uk-button-small" href="<?php echo e(url_for('book', ['id' => $book['book_id']])); ?>">紹介ページ</a></div></article><?php endforeach; ?></div><?php endif; ?>
