?><article class="uk-card uk-card-default rpm-card uk-card-body"><div class="uk-grid-large" uk-grid><div class="uk-width-1-3@m"><img class="rpm-book-cover" src="<?php echo e(asset_url($book['cover_path'] ?: '/upload/book/default-cover.svg')); ?>" alt="<?php echo e($book['title']); ?>"></div><div class="uk-width-expand"><h1><?php echo e($book['title']); ?></h1><p class="uk-text-lead"><?php echo e($book['author'] ?: '作者未設定'); ?></p><dl class="uk-description-list"><dt>発行機関</dt><dd><?php echo e($book['publisher'] ?: '未設定'); ?></dd><dt>進展管理単位</dt><dd><?php echo e(match($book['progress_unit']) {'chapter'=>'章','subsection'=>'小節',default=>'節'}); ?></dd><dt>進展時間粒度</dt><dd><?php echo e(progress_bucket_for_book($book) === 'hourly' ? '時間別' : '日別'); ?></dd><dt>メモ</dt><dd><?php echo nl2br(e($book['memo'] ?: 'メモはまだありません。')); ?></dd></dl><div class="uk-margin"><a class="uk-button uk-button-primary" href="<?php echo e(url_for('progress', ['id' => $book['book_id']])); ?>">読書進展管理へ</a><a class="uk-button rpm-button-soft" href="<?php echo e(url_for('books')); ?>">リストに戻る</a></div></div></div></article><section class="uk-margin-large-top"><h2>目次プレビュー</h2><?php if (!$toc): ?><p class="rpm-muted">目次はまだ導入されていません。</p><?php else: ?><ul class="uk-list uk-list-divider"><?php foreach ($toc as $item): ?><li style="padding-left:<?php echo e(((int)$item['level'] - 1) * 28); ?>px"><span class="uk-label"><?php echo e($item['display_prefix'] ?? match((int)$item['level']) {1=>'第 1 章',2=>'第 1 節',default=>'第 1 小節'}); ?></span> <?php echo e($item['plain_title'] ?? $item['title']); ?></li><?php endforeach; ?></ul><?php endif; ?></section>
