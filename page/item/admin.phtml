    if ($action === 'update_user') {
        $targetUid = (int)($_POST['uid'] ?? 0);
        $role = in_array((string)($_POST['role'] ?? 'user'), ['developer','super_admin','admin','user','banned'], true) ? (string)$_POST['role'] : 'user';
