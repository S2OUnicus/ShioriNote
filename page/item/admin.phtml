le']==='banned'?'selected':''; ?>>禁止され</option></select><select class="uk-select uk-form-small" name="status"><option value="active" <?php echo $u['status']==='active'?'selected':''; ?>>active</option><option value="suspended" <?php echo $u['status']==='suspended'?'selected':''; ?>>suspended</option></select><button class="uk-button uk-button-default uk-button-small" type="submit">保存</button></form></td></tr><?php endforeach; ?></tbody></table></div></section><section id="books" class="rpm-admin-section uk-card uk-card-default uk-card-body rpm-card uk-margin"><h2>図書管理</h2><h3>図書追加</h3><form method="post" enctype="multipart/form-data" action="<?php echo e(url_for('admin')); ?>"><?php echo csrf_field(); ?><input type="hidden" name="action" value="create_book"><div class="uk-grid-small uk-child-width-1-2@m" uk-grid><label>図書名<input class="uk-input" name="title" required></label><label>作者<input class="uk-input" name="author"></label><label>発行機関<input class="uk-input" name="publisher"></label><label>写真<input class="uk-input" type="file" name="cover" accept="image/png,image/jpeg,image/webp"></label><label>進展管理単位<select class="uk-select" name="progress_unit"><option value="section" selected>節</option><option value="chapter">章</option><option value="subsection">小節</option></select></label></div><div class="uk-margin"><label>メモ<textarea class="uk-textarea" name="memo" rows="3" maxlength="4000"></textarea></label></div><button class="uk-button uk-button-primary" type="submit">図書追加</button></form><hr><h3>目次導入（.txt / .md）</h3><p class="rpm-muted">フォーマット例：番号なしの章タイトル → インデントした節タイトル → さらにインデントした小節タイトル。画面では「第 1 章」「第 1 節」のように自動採番して表示します。既存目次は置き換えます。</p><form method="post" enctype="multipart/form-data" action="<?php echo e(url_for('admin')); ?>"><?php echo csrf_field(); ?><input type="hidden" name="action" value="import_toc"><div class="uk-grid-small uk-child-width-1-2@m" uk-grid><label>対象図書<select class="uk-select" name="book_id"><?php foreach ($books as $b): ?><option value="<?php 