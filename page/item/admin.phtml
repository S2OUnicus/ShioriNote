$progressRows = db()->query('SELECT p.uid,u.login_id,b.title,p.book_id,p.start_at_utc,p.completed_at_utc,p.updated_at_utc FROM user_book_progress p JOIN users u ON u.uid=p.uid JOIN books b ON b.book_id=p.book_id ORDER BY p.updated_at_utc DESC LIMIT 100')->fetchAll();
$tzs = timezone_identifiers_list();
