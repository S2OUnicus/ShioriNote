<?php
$admin = require_role(['developer', 'super_admin', 'admin']);
$pageDescription = 'サイト基本管理、ユーザー管理、図書管理、ユーザー別進展管理、その他を行います。';
if (!function_exists('parse_toc_text')) {
    function parse_toc_text(string $text): array
    {
        $lines = preg_split('/\R/u', $text) ?: [];
        $rows = [];
        foreach ($lines as $line) {
            if (trim($line) === '') {
                continue;
            }
            $raw = str_replace("\t", '    ', rtrim($line));
            $leading = strlen($raw) - strlen(ltrim($raw, ' '));
            $level = $leading === 0 ? 1 : ($leading < 8 ? 2 : 3);
            $title = trim(preg_replace('/^(?:#{1,6}\s*|[-*]\s*)/u', '', trim($raw)) ?? trim($raw));
            if ($title === '') {
                continue;
            }
            $rows[] = ['level' => $level, 'title' => clean_text($title, 255)];
        }
        return $rows;
    }
}

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    verify_csrf();
    $action = (string)($_POST['action'] ?? '');
    if ($action === 'settings') {
        require_role(['developer', 'super_admin']);
        save_setting('site_name', clean_text((string)($_POST['site_name'] ?? ''), 120));
        save_setting('author', clean_text((string)($_POST['author'] ?? ''), 120));
        $theme = preg_match('/^#[0-9A-Fa-f]{6}$/', (string)($_POST['theme_color'] ?? '')) ? (string)$_POST['theme_color'] : '#6E1E51';
        save_setting('theme_color', $theme);
        $tz = in_array((string)($_POST['default_timezone'] ?? ''), timezone_identifiers_list(), true) ? (string)$_POST['default_timezone'] : 'Asia/Tokyo';
        save_setting('default_timezone', $tz);
        save_setting('rewrite_enabled', isset($_POST['rewrite_enabled']) ? 'true' : 'false');
        save_setting('registration_enabled', isset($_POST['registration_enabled']) ? 'true' : 'false');
        save_setting('progress_time_bucket', ($_POST['progress_time_bucket'] ?? 'daily') === 'hourly' ? 'hourly' : 'daily');
        app_flash('success', 'サイト基本設定を保存しました。');
        redirect_to('admin');
    }
    if ($action === 'create_book') {
        $title = clean_text((string)($_POST['title'] ?? ''), 255);
        if ($title === '') {
            app_flash('danger', '図書名は必須です。');
        } else {
            $author = clean_text((string)($_POST['author'] ?? ''), 255);
            $publisher = clean_text((string)($_POST['publisher'] ?? ''), 255);
            $memo = clean_text((string)($_POST['memo'] ?? ''), 4000);
            $unit = in_array((string)($_POST['progress_unit'] ?? 'section'), ['chapter','section','subsection'], true) ? (string)$_POST['progress_unit'] : 'section';
            $cover = safe_image_upload($_FILES['cover'] ?? [], app_config('uploads')['book_dir'], 'book') ?? '';
            $stmt = db()->prepare('INSERT INTO books(title,author,publisher,cover_path,memo,progress_unit,created_by,created_at_utc,updated_at_utc) VALUES(?,?,?,?,?,?,?,UTC_TIMESTAMP(6),UTC_TIMESTAMP(6))');
            $stmt->execute([$title, $author, $publisher, $cover, $memo, $unit, (int)$admin['uid']]);
            app_flash('success', '図書を追加しました。続けて目次を導入できます。');
            redirect_to('admin', ['book_created' => (int)db()->lastInsertId()]);
        }
    }
    if ($action === 'import_toc') {
        $bookId = (int)($_POST['book_id'] ?? 0);
        $book = get_book($bookId);
        if (!$book) {
            app_flash('danger', '図書が見つかりません。');
        } elseif (($_FILES['toc_file']['error'] ?? UPLOAD_ERR_NO_FILE) !== UPLOAD_ERR_OK) {
            app_flash('danger', '目次ファイルを選択してください。');
        } elseif (($_FILES['toc_file']['size'] ?? 0) > app_config('uploads')['max_toc_bytes']) {
            app_flash('danger', '目次ファイルは1MB以内にしてください。');
        } else {
            $name = (string)($_FILES['toc_file']['name'] ?? '');
            $ext = strtolower(pathinfo($name, PATHINFO_EXTENSION));
            if (!in_array($ext, ['txt','md'], true)) {
                app_flash('danger', '目次ファイルは .txt または .md のみ利用できます。');
            } else {
                $text = file_get_contents($_FILES['toc_file']['tmp_name']);
                if ($text === false) {
                    throw new RuntimeException('目次ファイルを読み込めません。');
                }
                $rows = parse_toc_text($text);
                if (!$rows) {
                    app_flash('danger', '導入できる目次行がありません。');
                } else {
                    db()->beginTransaction();
                    try {
                        $stmt = db()->prepare('DELETE FROM book_toc WHERE book_id = ?');
                        $stmt->execute([$bookId]);
                        $parents = [0 => null, 1 => null, 2 => null, 3 => null];
                        $sort = 10;
                        foreach ($rows as $row) {
                            $level = (int)$row['level'];
                            $parentId = $level === 1 ? null : ($parents[$level - 1] ?? null);
                            if ($level > 1 && $parentId === null) {
                                $level = 1;
                            }
                            $stmt = db()->prepare('INSERT INTO book_toc(book_id,parent_id,level,sort_order,title,created_at_utc) VALUES(?,?,?,?,?,UTC_TIMESTAMP(6))');
                            $stmt->execute([$bookId, $parentId, $level, $sort, $row['title']]);
                            $parents[$level] = (int)db()->lastInsertId();
                            for ($i = $level + 1; $i <= 3; $i++) { $parents[$i] = null; }
                            $sort += 10;
                        }
                        db()->commit();
                        app_flash('success', '目次を導入しました。');
                        redirect_to('admin');
                    } catch (Throwable $e) {
                        db()->rollBack();
                        throw $e;
                    }
                }
            }
        }
    }
    if ($action === 'update_user') {
        $targetUid = (int)($_POST['uid'] ?? 0);
        $role = in_array((string)($_POST['role'] ?? 'user'), ['developer','super_admin','admin','user','banned'], true) ? (string)$_POST['role'] : 'user';
        $status = in_array((string)($_POST['status'] ?? 'active'), ['active','suspended'], true) ? (string)$_POST['status'] : 'active';
        if (role_rank($admin['role']) < 90 && $role !== 'user' && $role !== 'banned') {
            app_flash('danger', '管理者は上位権限を付与できません。');
        } else {
            $stmt = db()->prepare('UPDATE users SET role=?, status=?, updated_at_utc=UTC_TIMESTAMP(6) WHERE uid=?');
            $stmt->execute([$role, $status, $targetUid]);
            app_flash('success', 'ユーザー権限を更新しました。');
            redirect_to('admin');
        }
    }
}
