if (!function_exists('parse_toc_text')) {
    function parse_toc_text(string $text): array
    {
        $lines = preg_split('/\R/u', $text) ?: [];
        $rows = [];
        foreach ($lines as $line) {
            if (trim($line) === '') {
                continue;
            }
            $raw = str_replace("\t", '    ', rtrim($line));
            $leading = strlen($raw) - strlen(ltrim($raw, ' '));
            $level = $leading === 0 ? 1 : ($leading < 8 ? 2 : 3);
            $title = trim(preg_replace('/^(?:#{1,6}\s*|[-*]\s*)/u', '', trim($raw)) ?? trim($raw));
            if ($title === '') {
                continue;
            }
            $rows[] = ['level' => $level, 'title' => clean_text($title, 255)];
        }
        return $rows;
    }
}

