                } catch (Throwable $e) {
                    db()->rollBack();
                    throw $e;
                }
            } else {
                $stmt = db()->prepare("UPDATE user_toc_progress SET memo = '', updated_at_utc = UTC_TIMESTAMP(6) WHERE book_id = ?");
                $stmt->execute([$bookId]);
                app_flash('success', 'この図書の全ユーザーメモをリセットしました。');
            }
        }
        header('Location: ' . sn_admin_url('books', ['edit_book' => $bookId]));
        exit;
    }
    if ($action === 'update_progress_note' || $action === 'delete_progress_note') {
        $uid = (int)($_POST['uid'] ?? 0);
        $bookId = (int)($_POST['book_id'] ?? 0);
        $tocId = (int)($_POST['toc_id'] ?? 0);
