    if ($action === 'update_book') {
        $bookId = (int)($_POST['book_id'] ?? 0);
        $book = get_book($bookId);
        if (!$book) {
            app_flash('danger', '図書が見つかりません。');
            header('Location: ' . sn_admin_url('books'));
            exit;
        }
        $title = clean_text((string)($_POST['title'] ?? ''), 255);
        if ($title === '') {
            app_flash('danger', '図書名は必須です。');
            header('Location: ' . sn_admin_url('books'));
            exit;
        }
        $author = clean_text((string)($_POST['author'] ?? ''), 255);
        $publisher = clean_text((string)($_POST['publisher'] ?? ''), 255);
        $memo = clean_text((string)($_POST['memo'] ?? ''), 4000);
        $unit = in_array((string)($_POST['progress_unit'] ?? 'section'), ['chapter','section','subsection'], true) ? (string)$_POST['progress_unit'] : 'section';
        $bucket = (($_POST['progress_time_bucket'] ?? 'daily') === 'hourly') ? 'hourly' : 'daily';
        $mindmapDepth = in_array((string)($_POST['mindmap_depth'] ?? 'section'), ['chapter','section','subsection'], true) ? (string)$_POST['mindmap_depth'] : 'section';
        $chapterChartStyle = (($_POST['chapter_chart_style'] ?? 'rounded') === 'horizontal') ? 'horizontal' : 'rounded';
        $cover = safe_image_upload($_FILES['cover'] ?? [], app_config('uploads')['book_dir'], 'book') ?? (string)$book['cover_path'];
        $stmt = db()->prepare('UPDATE books SET title=?, author=?, publisher=?, cover_path=?, memo=?, progress_unit=?, progress_time_bucket=?, mindmap_depth=?, chapter_chart_style=?, updated_at_utc=UTC_TIMESTAMP(6) WHERE book_id=?');
        $stmt->execute([$title, $author, $publisher, $cover, $memo, $unit, $bucket, $mindmapDepth, $chapterChartStyle, $bookId]);
        app_flash('success', '図書の基本情報を更新しました。');
