        $stmt = db()->prepare('INSERT INTO books(title,author,publisher,cover_path,memo,progress_unit,progress_time_bucket,mindmap_depth,chapter_chart_style,created_by,created_at_utc,updated_at_utc) VALUES(?,?,?,?,?,?,?,?,?,?,UTC_TIMESTAMP(6),UTC_TIMESTAMP(6))');
