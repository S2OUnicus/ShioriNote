<?php
$pageDescription = 'IDまたはメールでログインできます。';
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    verify_csrf();
    $login = trim((string)($_POST['login'] ?? ''));
    $password = (string)($_POST['password'] ?? '');
    if ($login === '' || $password === '') {
        app_flash('danger', 'ログイン情報を入力してください。');
    } else {
        $stmt = db()->prepare('SELECT * FROM users WHERE LOWER(login_id) = LOWER(?) OR LOWER(email) = LOWER(?) LIMIT 1');
        $stmt->execute([$login, $login]);
        $user = $stmt->fetch();
        if ($user && verify_password_bundle($password, $user['password_salt'], $user['password_hash'])) {
            session_regenerate_id(true);
            $_SESSION['uid'] = (int)$user['uid'];
            $stmt = db()->prepare('UPDATE users SET last_login_at_utc = UTC_TIMESTAMP(6) WHERE uid = ?');
            $stmt->execute([(int)$user['uid']]);
            app_flash('success', 'ログインしました。');
            redirect_to('index');
        }
        app_flash('danger', 'ログイン情報が正しくありません。');
    }
}
?><section class="uk-card uk-card-default uk-card-body rpm-card rpm-login-card"><h1>ログイン</h1><form method="post" action="<?php echo e(url_for('login')); ?>"><?php echo csrf_field(); ?><div class="uk-margin"><label>ID / メール<input class="uk-input" name="login" autocomplete="username" required></label></div><div class="uk-margin"><label>パスワード<input class="uk-input" type="password" name="password" autocomplete="current-password" required></label></div><button class="uk-button uk-button-primary" type="submit">ログイン</button><a class="uk-button uk-button-text uk-margin-left" href="<?php echo e(url_for('forgot')); ?>">パスワード忘れ</a><?php if (registration_enabled()): ?><a class="uk-button uk-button-text uk-margin-left" href="<?php echo e(url_for('register')); ?>">新規登録</a><?php else: ?><p class="uk-text-meta uk-margin-small-top">現在、新規登録は停止されています。</p><?php endif; ?></form></section>
