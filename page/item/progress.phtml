    function sn_mindmap_depth_level(array $book): int
    {
        return match ((string)($book['mindmap_depth'] ?? 'section')) {
            'chapter' => 1,
            'subsection' => 3,
            default => 2,
        };
    }

    function sn_mindmap_node(array $node, array $childrenByParent, int $maxLevel): array
    {
        $data = ['name' => $node['display_title'] ?? $node['title']];
        if ((int)$node['level'] < $maxLevel) {
            $children = [];
            foreach ($childrenByParent[(int)$node['toc_id']] ?? [] as $child) {
                if ((int)$child['level'] <= $maxLevel) {
                    $children[] = sn_mindmap_node($child, $childrenByParent, $maxLevel);
                }
            }
            if ($children) {
                $data['children'] = $children;
            }
        }
        return $data;
    }

    function sn_mindmap_tree_data(array $book, array $toc): array
    {
        $childrenByParent = sn_toc_children_by_parent($toc);
        $chapters = array_values(array_filter($toc, fn($x) => (int)$x['level'] === 1));
        $maxLevel = sn_mindmap_depth_level($book);
        $chapterNodes = [];
        foreach ($chapters as $chapter) {
            $chapterNodes[] = sn_mindmap_node($chapter, $childrenByParent, $maxLevel);
        }
        $rootMode = (string)($book['mindmap_root'] ?? 'chapter');
        return ['name' => $rootMode === 'book' ? $book['title'] : '', 'children' => $chapterNodes, 'rootMode' => $rootMode === 'book' ? 'book' : 'chapter'];
    }

