    function sn_toc_children_by_parent(array $toc): array
    {
        $children = [];
        foreach ($toc as $item) {
            $children[(int)($item['parent_id'] ?? 0)][] = $item;
        }
        return $children;
    }

    function sn_target_descendants(array $root, array $childrenByParent, string $unit): array
    {
        $targetLevel = target_toc_level($unit);
        $desc = [];
        $stack = [$root];
        while ($stack) {
            $node = array_pop($stack);
            if ((int)$node['level'] === $targetLevel) {
                $desc[] = $node;
            }
            foreach (array_reverse($childrenByParent[(int)$node['toc_id']] ?? []) as $child) {
                $stack[] = $child;
            }
        }
        if (!$desc && $unit !== 'chapter') {
            $desc = [$root];
        }
        return $desc;
    }

    function sn_completed_records(array $user, array $book, array $targetItems, array $progressByToc): array
    {
        $bucketType = progress_bucket_for_book($book);
        $records = [];
        foreach ($targetItems as $item) {
            $tocId = (int)$item['toc_id'];
            $p = $progressByToc[$tocId] ?? null;
            if (!$p || (int)($p['percent'] ?? 0) !== 100 || empty($p['completed_at_utc'])) {
                continue;
            }
            try {
                $dt = new DateTimeImmutable((string)$p['completed_at_utc'], new DateTimeZone('UTC'));
            } catch (Throwable) {
                continue;
            }
            $local = $dt->setTimezone(user_timezone($user));
            $bucketKey = $bucketType === 'hourly' ? $local->format('Y-m-d H:00:00') : $local->format('Y-m-d 00:00:00');
            $bucketLabel = $bucketType === 'hourly' ? $local->format('Y-m-d H:00') : $local->format('Y-m-d');
            $records[] = [
                'bucket_key' => $bucketKey,
                'bucket_label' => $bucketLabel,
                'completed_at_utc' => (string)$p['completed_at_utc'],
                'title' => $item['display_title'] ?? $item['title'],
            ];
        }
        usort($records, fn($a, $b) => strcmp($a['bucket_key'], $b['bucket_key']));
        return $records;
    }

    function sn_progress_context(array $user, array $book, array $toc, array $targetItems, array $progressByToc): array
    {
        $overall = compute_overall_percent($targetItems, $progressByToc);
        $chapters = array_values(array_filter($toc, fn($x) => (int)$x['level'] === 1));
        $childrenByParent = sn_toc_children_by_parent($toc);
        $chapterLabels = [];
        $chapterPercents = [];
        foreach ($chapters as $i => $chapter) {
            $chapterLabels[] = ($i + 1) . '章';
            $desc = sn_target_descendants($chapter, $childrenByParent, (string)$book['progress_unit']);
            $chapterPercents[] = compute_overall_percent($desc, $progressByToc);
        }
        $bucketType = progress_bucket_for_book($book);
        $records = sn_completed_records($user, $book, $targetItems, $progressByToc);
        $groups = [];
        foreach ($records as $record) {
            $key = $record['bucket_key'];
            if (!isset($groups[$key])) {
                $groups[$key] = ['label' => $record['bucket_label'], 'items' => []];
            }
            $groups[$key]['items'][] = $record['title'];
        }
        ksort($groups);
        $bucketLabels = [];
        $bucketDelta = [];
        $bucketTotal = [];
        $summaryRows = [];
        $totalTargets = max(1, count($targetItems));
        $countDone = 0;
        foreach ($groups as $group) {
            $count = count($group['items']);
            $countDone += $count;
            $bucketLabels[] = $group['label'];
            $bucketDelta[] = $count;
            $bucketTotal[] = round($countDone / $totalTargets * 100, 2);
            $summaryRows[] = ['label' => $group['label'], 'count' => $count, 'items' => $group['items']];
        }
        if (!$bucketLabels) {
            $bucketLabels[] = '現在';
            $bucketDelta[] = 0;
            $bucketTotal[] = $overall;
        }
        $summaryRows = array_reverse($summaryRows);
        $chartData = json_encode([
            'chapterLabels' => $chapterLabels,
            'chapterPercents' => $chapterPercents,
            'chapterRemaining' => array_map(fn($v) => max(0, 100 - (float)$v), $chapterPercents),
            'bucketLabels' => $bucketLabels,
            'bucketDelta' => $bucketDelta,
            'bucketTotal' => $bucketTotal,
            'bucketType' => $bucketType,
            'chapterChartStyle' => in_array((string)($book['chapter_chart_style'] ?? 'rounded'), ['rounded','horizontal'], true) ? (string)$book['chapter_chart_style'] : 'rounded',
        ], JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT);
        return ['overall' => $overall, 'bucketType' => $bucketType, 'chartData' => $chartData, 'summaryRows' => $summaryRows];
    }

