    function sn_items_in_chapter(array $toc, int $chapterId): array
    {
        $items = [];
        $inside = false;
        foreach ($toc as $item) {
            if ((int)$item['level'] === 1) {
                if ($inside && (int)$item['toc_id'] !== $chapterId) {
                    break;
                }
                $inside = (int)$item['toc_id'] === $chapterId;
            }
            if ($inside) {
                $items[] = $item;
            }
        }
        return $items;
    }

