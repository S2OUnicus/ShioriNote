<?php
$user = require_not_banned();
$bookId = (int)($routeId ?? ($_GET['id'] ?? 0));
$book = get_book($bookId);
if (!$book) { http_response_code(404); throw new RuntimeException('図書が見つかりません。'); }
$pageDescription = $book['title'] . 'の読書進展ページです。';
$toc = get_book_toc($bookId);
$targetItems = target_toc_items($toc, $book['progress_unit']);

if (!function_exists('sn_progress_context')) {
    function sn_progress_context(array $user, array $book, array $toc, array $targetItems, array $progressByToc): array
    {
        $overall = compute_overall_percent($targetItems, $progressByToc);
        $chapters = array_values(array_filter($toc, fn($x) => (int)$x['level'] === 1));
        $childrenByParent = [];
        foreach ($toc as $item) {
            $childrenByParent[(int)($item['parent_id'] ?? 0)][] = $item;
        }
        $chapterLabels = [];
        $chapterPercents = [];
        foreach ($chapters as $chapter) {
            $chapterLabels[] = $chapter['display_title'] ?? $chapter['title'];
            $desc = [];
            $stack = [$chapter];
            while ($stack) {
                $n = array_pop($stack);
                if ((int)$n['level'] === target_toc_level($book['progress_unit'])) {
                    $desc[] = $n;
                }
                foreach ($childrenByParent[(int)$n['toc_id']] ?? [] as $ch) {
                    $stack[] = $ch;
                }
            }
            if (!$desc && $book['progress_unit'] !== 'chapter') {
                $desc = [$chapter];
            }
            $chapterPercents[] = compute_overall_percent($desc, $progressByToc);
        }
        $bucketType = setting('progress_time_bucket', 'daily') === 'hourly' ? 'hourly' : 'daily';
        $groupFmt = $bucketType === 'hourly' ? '%Y-%m-%d %H:00:00' : '%Y-%m-%d 00:00:00';
        $stmt = db()->prepare("SELECT DATE_FORMAT(bucket_at_utc, '$groupFmt') AS bucket_label_utc, SUM(progress_delta) AS delta_sum, MAX(total_percent_after) AS total_after FROM progress_logs WHERE uid = ? AND book_id = ? AND bucket_type = ? GROUP BY bucket_label_utc ORDER BY bucket_label_utc ASC LIMIT 60");
        $stmt->execute([(int)$user['uid'], (int)$book['book_id'], $bucketType]);
        $logs = $stmt->fetchAll();
        $bucketLabels = [];
        $bucketDelta = [];
        $bucketTotal = [];
        foreach ($logs as $log) {
            $bucketLabels[] = utc_to_user($log['bucket_label_utc'], $user, $bucketType === 'hourly' ? 'm/d H:00' : 'm/d');
            $bucketDelta[] = round((float)$log['delta_sum'], 2);
            $bucketTotal[] = round((float)$log['total_after'], 2);
        }
        if (!$bucketLabels) {
            $bucketLabels[] = '現在';
            $bucketDelta[] = 0;
            $bucketTotal[] = $overall;
        }
        $chartData = json_encode([
            'chapterLabels' => $chapterLabels,
            'chapterPercents' => $chapterPercents,
            'bucketLabels' => $bucketLabels,
            'bucketDelta' => $bucketDelta,
            'bucketTotal' => $bucketTotal,
        ], JSON_UNESCAPED_UNICODE | JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT);
        return ['overall' => $overall, 'bucketType' => $bucketType, 'chartData' => $chartData];
    }

    function sn_render_progress_summary(array $user, array $book, array $bookProgress, float $overall, string $bucketType, bool $oob = false): void
    {
        $oobAttr = $oob ? ' hx-swap-oob="outerHTML"' : '';
        ?><div id="rpm-progress-summary"<?php echo $oobAttr; ?>><section class="uk-margin-bottom rpm-progress-head"><div class="uk-flex uk-flex-between uk-flex-middle uk-flex-wrap"><div><h1><?php echo e($book['title']); ?></h1><p class="rpm-muted">管理単位：<?php echo e(match($book['progress_unit']) {'chapter'=>'章','subsection'=>'小節',default=>'節'}); ?> / 表示時間：<?php echo e($bucketType === 'hourly' ? '時間別' : '日別'); ?> / Timezone: <?php echo e($user['timezone']); ?></p></div><?php if ($overall >= 100): ?><div class="rpm-stamp">完結</div><?php endif; ?></div><div class="rpm-progress-wrap"><progress class="uk-progress" value="<?php echo e((string)$overall); ?>" max="100"></progress><span class="rpm-progress-number"><?php echo e((string)$overall); ?>%</span></div></section><section class="uk-card uk-card-default uk-card-body rpm-card uk-margin"><h2>基本情報</h2><div class="rpm-basic-info"><div class="rpm-info-pill"><strong>図書名</strong><?php echo e($book['title']); ?></div><div class="rpm-info-pill"><strong>開始時間</strong><?php echo e(utc_to_user($bookProgress['start_at_utc'] ?? '', $user) ?: '未設定'); ?></div><div class="rpm-info-pill"><strong>完結時間</strong><?php echo e(utc_to_user($bookProgress['completed_at_utc'] ?? '', $user) ?: '未設定'); ?></div></div></section></div><?php
    }

    function sn_render_chart_zone(string $chartData, string $bucketType, bool $oob = false): void
    {
        $oobAttr = $oob ? ' hx-swap-oob="outerHTML"' : '';
        ?><section id="rpm-chart-zone" class="rpm-chart-grid uk-margin-large"<?php echo $oobAttr; ?>><script type="application/json" id="progress-chart-data"><?php echo $chartData; ?></script><div class="uk-card uk-card-default uk-card-body rpm-card"><h2>章ごと進展</h2><div id="chart-polar" class="rpm-chart"></div></div><div class="uk-card uk-card-default uk-card-body rpm-card"><h2>章ごと進展と残り</h2><div id="chart-stacked" class="rpm-chart"></div></div><div class="uk-card uk-card-default uk-card-body rpm-card"><h2>総進展と<?php echo e($bucketType === 'hourly' ? '時間別' : '日別'); ?>進展</h2><div id="chart-mixed" class="rpm-chart"></div></div></section><?php
    }

    function sn_render_completed_input(array $user, array $bookProgress, bool $oob = false): void
    {
        $oobAttr = $oob ? ' hx-swap-oob="outerHTML"' : '';
        ?><input id="rpm-completed-at-input" class="uk-input" type="datetime-local" name="completed_at" value="<?php echo e(utc_to_user($bookProgress['completed_at_utc'] ?? '', $user, 'Y-m-d\TH:i')); ?>"<?php echo $oobAttr; ?>><?php
    }
}

$bookProgress = ensure_user_book_progress((int)$user['uid'], $bookId);
$progressByToc = fetch_progress_by_toc((int)$user['uid'], $bookId);
$previousOverall = compute_overall_percent($targetItems, $progressByToc);

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    verify_csrf();
    $startUtc = user_local_to_utc($_POST['start_at'] ?? '', $user);
    $completedUtc = user_local_to_utc($_POST['completed_at'] ?? '', $user);
    db()->beginTransaction();
    try {
        $stmt = db()->prepare('UPDATE user_book_progress SET start_at_utc = ?, completed_at_utc = ?, updated_at_utc = UTC_TIMESTAMP(6) WHERE uid = ? AND book_id = ?');
        $stmt->execute([$startUtc, $completedUtc, (int)$user['uid'], $bookId]);
        $inputProgress = $_POST['progress'] ?? [];
        $inputMemo = $_POST['memo'] ?? [];
        foreach ($targetItems as $item) {
            $tocId = (int)$item['toc_id'];
            $percent = (int)($inputProgress[$tocId] ?? 0);
            $percent = max(0, min(100, $percent));
            $checked = $percent === 100 ? 1 : 0;
            $memo = clean_text((string)($inputMemo[$tocId] ?? ''), 2000);
            $stmt = db()->prepare('INSERT INTO user_toc_progress(uid, book_id, toc_id, percent, is_checked, memo, updated_at_utc) VALUES(?, ?, ?, ?, ?, ?, UTC_TIMESTAMP(6)) ON DUPLICATE KEY UPDATE percent = VALUES(percent), is_checked = VALUES(is_checked), memo = VALUES(memo), updated_at_utc = UTC_TIMESTAMP(6)');
            $stmt->execute([(int)$user['uid'], $bookId, $tocId, $percent, $checked, $memo]);
        }
        $progressByToc = fetch_progress_by_toc((int)$user['uid'], $bookId);
        $newOverall = compute_overall_percent($targetItems, $progressByToc);
        if ($newOverall >= 100.0) {
            $stmt = db()->prepare('UPDATE user_book_progress SET completed_at_utc = COALESCE(completed_at_utc, UTC_TIMESTAMP(6)), updated_at_utc = UTC_TIMESTAMP(6) WHERE uid = ? AND book_id = ?');
            $stmt->execute([(int)$user['uid'], $bookId]);
        }
        $bucketType = setting('progress_time_bucket', 'daily') === 'hourly' ? 'hourly' : 'daily';
        $delta = round(max(0, $newOverall - $previousOverall), 2);
        if ($delta > 0) {
            $stmt = db()->prepare('INSERT INTO progress_logs(uid, book_id, bucket_type, bucket_at_utc, progress_delta, total_percent_after, created_at_utc) VALUES(?, ?, ?, UTC_TIMESTAMP(6), ?, ?, UTC_TIMESTAMP(6))');
            $stmt->execute([(int)$user['uid'], $bookId, $bucketType, $delta, $newOverall]);
        }
        db()->commit();

        $bookProgress = ensure_user_book_progress((int)$user['uid'], $bookId);
        $progressByToc = fetch_progress_by_toc((int)$user['uid'], $bookId);
        $ctx = sn_progress_context($user, $book, $toc, $targetItems, $progressByToc);
        if (strtolower($_SERVER['HTTP_HX_REQUEST'] ?? '') === 'true') {
            header('HX-Trigger: shiorinoteProgressSaved');
            ?><div class="uk-alert-success rpm-autosave-alert" uk-alert><p>保存しました。</p></div><?php sn_render_progress_summary($user, $book, $bookProgress, (float)$ctx['overall'], (string)$ctx['bucketType'], true); sn_render_chart_zone((string)$ctx['chartData'], (string)$ctx['bucketType'], true); sn_render_completed_input($user, $bookProgress, true); exit;
        }
        app_flash('success', '読書進展を保存しました。');
        redirect_to('progress', ['id' => $bookId]);
    } catch (Throwable $e) {
        db()->rollBack();
        if (strtolower($_SERVER['HTTP_HX_REQUEST'] ?? '') === 'true') {
            http_response_code(500);
            ?><div class="uk-alert-danger rpm-autosave-alert" uk-alert><p><?php echo e($e->getMessage()); ?></p></div><?php
            exit;
        }
        throw $e;
    }
}

$ctx = sn_progress_context($user, $book, $toc, $targetItems, $progressByToc);
$overall = (float)$ctx['overall'];
$bucketType = (string)$ctx['bucketType'];
$chartData = (string)$ctx['chartData'];
?><div class="rpm-progress-layout"><aside class="rpm-progress-side"><?php sn_render_progress_summary($user, $book, $bookProgress, $overall, $bucketType); ?><?php sn_render_chart_zone($chartData, $bucketType); ?><section class="uk-card uk-card-default uk-card-body rpm-card uk-margin-large"><h2>図書の基本情報カード</h2><div class="rpm-book-info-card"><img class="rpm-book-cover-sm" src="<?php echo e($book['cover_path'] ?: '/upload/book/default-cover.svg'); ?>" alt="<?php echo e($book['title']); ?>"><div><h3><?php echo e($book['title']); ?></h3><p class="uk-text-meta"><?php echo e($book['author'] ?: '作者未設定'); ?> / <?php echo e($book['publisher'] ?: '発行機関未設定'); ?></p><p><?php echo nl2br(e($book['memo'] ?: 'メモはまだありません。')); ?></p></div></div></section></aside><section class="rpm-progress-main"><form id="rpm-progress-form" class="rpm-progress-form uk-card uk-card-default uk-card-body rpm-card" method="post" action="<?php echo e(url_for('progress', ['id' => $bookId])); ?>" hx-post="<?php echo e(url_for('progress', ['id' => $bookId])); ?>" hx-target="#rpm-autosave-status" hx-swap="innerHTML"><?php echo csrf_field(); ?><div class="uk-flex uk-flex-between uk-flex-middle uk-flex-wrap rpm-form-head"><h2>目次進展</h2><div id="rpm-autosave-status" class="rpm-autosave-status" aria-live="polite"></div></div><div class="uk-grid-small uk-child-width-1-2@m" uk-grid><label>開始時間<input id="rpm-start-at-input" class="uk-input" type="datetime-local" name="start_at" value="<?php echo e(utc_to_user($bookProgress['start_at_utc'] ?? '', $user, 'Y-m-d\TH:i')); ?>"></label><label>完結時間<?php sn_render_completed_input($user, $bookProgress); ?></label></div><?php if (!$targetItems): ?><p class="uk-alert-warning">管理対象の目次がありません。管理システムから目次を導入してください。</p><?php else: ?><ul class="rpm-toc uk-margin-top"><?php foreach ($toc as $item): $tocTitle = $item['display_title'] ?? $item['title']; $isTarget = (int)$item['level'] === target_toc_level($book['progress_unit']); if (!$isTarget) { ?><li class="rpm-toc-row level-<?php echo e($item['level']); ?>"><span></span><span class="rpm-toc-title"><?php echo e($tocTitle); ?></span><span></span><span></span></li><?php continue; } $p = $progressByToc[(int)$item['toc_id']] ?? ['percent'=>0,'memo'=>'']; ?><li class="rpm-toc-row level-<?php echo e($item['level']); ?>"><input class="uk-checkbox rpm-progress-check" type="checkbox" <?php echo ((int)$p['percent'] === 100) ? 'checked' : ''; ?> aria-label="読了"><span class="rpm-toc-title"><?php echo e($tocTitle); ?></span><input class="uk-input rpm-percent-input" type="number" name="progress[<?php echo e($item['toc_id']); ?>]" min="0" max="100" step="1" value="<?php echo e($p['percent']); ?>" inputmode="numeric"><textarea class="uk-textarea rpm-memo-input" name="memo[<?php echo e($item['toc_id']); ?>]" rows="1" maxlength="2000" placeholder="メモ欄"><?php echo e($p['memo'] ?? ''); ?></textarea></li><?php endforeach; ?></ul><?php endif; ?></form></section></div>
