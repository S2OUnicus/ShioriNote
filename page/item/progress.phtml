$bookProgress = ensure_user_book_progress((int)$user['uid'], $bookId);
$progressByToc = fetch_progress_by_toc((int)$user['uid'], $bookId);
$previousOverall = compute_overall_percent($targetItems, $progressByToc);

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    verify_csrf();
    $startUtc = user_local_to_utc($_POST['start_at'] ?? '', $user);
    $completedUtc = user_local_to_utc($_POST['completed_at'] ?? '', $user);
    db()->beginTransaction();
    try {
        $stmt = db()->prepare('UPDATE user_book_progress SET start_at_utc = ?, completed_at_utc = ?, updated_at_utc = UTC_TIMESTAMP(6) WHERE uid = ? AND book_id = ?');
        $stmt->execute([$startUtc, $completedUtc, (int)$user['uid'], $bookId]);
        $inputProgress = $_POST['progress'] ?? [];
        $inputMemo = $_POST['memo'] ?? [];
        $inputCompleted = $_POST['completed_at_item'] ?? [];
        foreach ($targetItems as $item) {
            $tocId = (int)$item['toc_id'];
            $old = $progressByToc[$tocId] ?? [];
            $percent = (int)($inputProgress[$tocId] ?? 0);
            $percent = max(0, min(100, $percent));
            $checked = $percent === 100 ? 1 : 0;
            $memo = clean_text(str_replace(["\r", "\n"], ' ', (string)($inputMemo[$tocId] ?? '')), 1000);
            $completedItemUtc = null;
            if ($percent === 100) {
                $submittedCompleted = trim((string)($inputCompleted[$tocId] ?? ''));
                if ($submittedCompleted !== '') {
                    $completedItemUtc = user_local_to_utc($submittedCompleted, $user);
                } elseif (!empty($old['completed_at_utc'])) {
                    $completedItemUtc = (string)$old['completed_at_utc'];
                } else {
                    $completedItemUtc = utc_now();
                }
            }
            $stmt = db()->prepare('INSERT INTO user_toc_progress(uid, book_id, toc_id, percent, is_checked, memo, completed_at_utc, updated_at_utc) VALUES(?, ?, ?, ?, ?, ?, ?, UTC_TIMESTAMP(6)) ON DUPLICATE KEY UPDATE percent = VALUES(percent), is_checked = VALUES(is_checked), memo = VALUES(memo), completed_at_utc = VALUES(completed_at_utc), updated_at_utc = UTC_TIMESTAMP(6)');
            $stmt->execute([(int)$user['uid'], $bookId, $tocId, $percent, $checked, $memo, $completedItemUtc]);
        }
        $progressByToc = fetch_progress_by_toc((int)$user['uid'], $bookId);
        $newOverall = compute_overall_percent($targetItems, $progressByToc);
        if ($newOverall >= 100.0) {
            $stmt = db()->prepare('UPDATE user_book_progress SET completed_at_utc = COALESCE(completed_at_utc, UTC_TIMESTAMP(6)), updated_at_utc = UTC_TIMESTAMP(6) WHERE uid = ? AND book_id = ?');
            $stmt->execute([(int)$user['uid'], $bookId]);
        }
        $bucketTypeForLog = progress_bucket_for_book($book);
        $delta = round(max(0, $newOverall - $previousOverall), 2);
        if ($delta > 0) {
            $stmt = db()->prepare('INSERT INTO progress_logs(uid, book_id, bucket_type, bucket_at_utc, progress_delta, total_percent_after, created_at_utc) VALUES(?, ?, ?, UTC_TIMESTAMP(6), ?, ?, UTC_TIMESTAMP(6))');
            $stmt->execute([(int)$user['uid'], $bookId, $bucketTypeForLog, $delta, $newOverall]);
        }
        db()->commit();

        $bookProgress = ensure_user_book_progress((int)$user['uid'], $bookId);
        $progressByToc = fetch_progress_by_toc((int)$user['uid'], $bookId);
        $ctx = sn_progress_context($user, $book, $toc, $targetItems, $progressByToc);
        if (strtolower($_SERVER['HTTP_HX_REQUEST'] ?? '') === 'true') {
            header('HX-Trigger: shiorinoteProgressSaved');
            ?><div class="uk-alert-success rpm-autosave-alert" uk-alert><p>保存しました。</p></div><?php sn_render_progress_summary($user, $book, $bookProgress, (float)$ctx['overall'], (string)$ctx['bucketType'], true); sn_render_progress_status($user, $book, $bookProgress, true); sn_render_chart_zone((string)$ctx['chartData'], $book, true); sn_render_toc_section($user, $book, $bookProgress, $toc, $targetItems, $progressByToc, $ctx['summaryRows'], (string)$ctx['bucketType'], true); exit;
        }
        app_flash('success', '読書進展を保存しました。');
        if ($isAdminProgress) {
            header('Location: ' . $progressAction);
            exit;
        }
        redirect_to('progress', ['id' => $bookId]);
    } catch (Throwable $e) {
        db()->rollBack();
        if (strtolower($_SERVER['HTTP_HX_REQUEST'] ?? '') === 'true') {
            http_response_code(500);
            ?><div class="uk-alert-danger rpm-autosave-alert" uk-alert><p><?php echo e($e->getMessage()); ?></p></div><?php
            exit;
        }
        throw $e;
    }
}

$ctx = sn_progress_context($user, $book, $toc, $targetItems, $progressByToc);
$overall = (float)$ctx['overall'];
$bucketType = (string)$ctx['bucketType'];
$chartData = (string)$ctx['chartData'];
?>
<?php if ($isAdminProgress): ?><section class="uk-alert-warning rpm-admin-progress-warning" uk-alert><p>今は「<?php echo e(role_label_ja((string)($progressAdmin['role'] ?? 'admin'))); ?>」として、<?php echo e($user['login_id']); ?> さんの「<?php echo e($book['title']); ?>」を管理します。</p><p><a href="<?php echo e($progressBackUrl); ?>">ユーザー別進展管理へ戻る</a></p></section><?php endif; ?>
<div class="rpm-progress-page"><div class="rpm-progress-top"><?php sn_render_progress_summary($user, $book, $bookProgress, $overall, $bucketType); ?></div><div id="rpm-progress-body" class="rpm-progress-layout"><aside class="rpm-progress-side"><section class="uk-card uk-card-default uk-card-body rpm-card rpm-book-info-card-section"><h2>図書情報</h2><div class="rpm-book-info-card"><img class="rpm-book-cover-sm" src="<?php echo e(asset_url($book['cover_path'] ?: '/upload/book/default-cover.svg')); ?>" alt="<?php echo e($book['title']); ?>"><div><h3><?php echo e($book['title']); ?></h3><p class="uk-text-meta"><?php echo e($book['author'] ?: '作者未設定'); ?> / <?php echo e($book['publisher'] ?: '発行機関未設定'); ?></p><p><?php echo nl2br(e($book['memo'] ?: 'メモはまだありません。')); ?></p></div></div></section><?php sn_render_chart_zone($chartData, $book); ?><?php sn_render_progress_status($user, $book, $bookProgress); ?></aside><section class="rpm-progress-main"><?php sn_render_mindmap_summary($book, $toc); ?><form id="rpm-progress-form" class="rpm-progress-form uk-card uk-card-default uk-card-body rpm-card" method="post" action="<?php echo e($progressAction); ?>" hx-post="<?php echo e($progressAction); ?>" hx-target="#rpm-autosave-status" hx-swap="innerHTML"><?php echo csrf_field(); ?><input type="hidden" name="action" value="progress_save"><div class="uk-flex uk-flex-between uk-flex-middle uk-flex-wrap rpm-form-head"><h2>目次進展</h2><div id="rpm-autosave-status" class="rpm-autosave-status" aria-live="polite"></div></div><?php sn_render_toc_section($user, $book, $bookProgress, $toc, $targetItems, $progressByToc, $ctx['summaryRows'], $bucketType); ?></form></section></div></div>
